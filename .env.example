# OpenRouter API key used to call Gemini-family models through OpenRouter.
VITE_OPENROUTER_API_KEY="YOUR_OPENROUTER_API_KEY"

# Gemini model on OpenRouter with lighter usage profile.
VITE_OPENROUTER_MODEL="google/gemini-2.0-flash-lite-001"

# Minimum delay between OpenRouter requests (ms) to reduce rate-limit pressure.
VITE_OPENROUTER_MIN_INTERVAL_MS="2500"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Backend API base URL for shared dashboard sync service.
VITE_API_BASE_URL="http://localhost:8000/api/v1"

# Unique source key for this dashboard instance.
VITE_DASHBOARD_SOURCE="dashboard-web"
